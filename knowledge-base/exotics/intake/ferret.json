{
  "key": "ferret",
  "label": "雪貂结构化问诊模板",
  "species_scope": [
    "ferret"
  ],
  "summary": "围绕雪貂低血糖样虚弱、胃肠异物、腹泻脱水、肾上腺/皮肤、泌尿生殖、呼吸、肿块和外伤神经风险采集结构化病史。",
  "feature_flags": [
    "hypoglycemia_signs",
    "weakness",
    "drooling",
    "foreign_body_risk",
    "vomiting",
    "diarrhea",
    "collapse",
    "seizures",
    "hindlimb_weakness",
    "regurgitation",
    "abd_distension",
    "feces_down",
    "black_tarry_stool",
    "dehydration",
    "appetite_down",
    "respiratory_distress",
    "coughing",
    "nasal_ocular_discharge",
    "urinary_issue",
    "hair_loss",
    "pruritus",
    "vulvar_swelling",
    "weight_loss",
    "mass_or_swelling",
    "trauma",
    "neurologic_signs"
  ],
  "red_flag_prompts": [
    "雪貂突然虚弱、流口水、后肢无力、发呆、抽搐或虚脱时，优先按低血糖样高风险处理。",
    "呕吐/腹痛合并啃咬橡胶、泡棉、玩具或布料时，需警惕胃肠异物。",
    "呕吐/腹痛/便少合并啃咬橡胶、泡棉、玩具、耳塞、鞋垫或布料时，需警惕胃肠异物或部分梗阻。",
    "张口呼吸、发绀、严重喘促、疑似尿闭、黑便/血便或不能站立时，不应等待模板补全后再分诊。",
    "本模板只做异宠分诊和病史采集，不输出处方、剂量、给药途径或治疗计划。"
  ],
  "sections": [
    {
      "key": "signalment",
      "title": "基础信息 / 风险背景",
      "priority": "core",
      "questions": [
        {
          "key": "age_sex_neuter",
          "label": "年龄、性别、是否绝育/去味、疫苗和驱虫情况",
          "answer_type": "text",
          "required": true,
          "clinical_reason": "年龄和绝育状态影响内分泌、肿瘤样问题和常见病判断。"
        },
        {
          "key": "weight_trend",
          "label": "当前体重、近期体重变化和体况",
          "answer_type": "text",
          "required": true,
          "clinical_reason": "体重下降和体况变化是慢性病、脱水和营养风险线索。"
        },
        {
          "key": "housing_animals",
          "label": "单只还是多只饲养？同住动物是否有类似症状？",
          "answer_type": "text",
          "required": false,
          "clinical_reason": "群体信息有助于判断感染、环境暴露和饮食问题。"
        }
      ]
    },
