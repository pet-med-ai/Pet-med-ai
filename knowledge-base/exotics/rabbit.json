  "checks": [
    "体重、体况、脱水和黏膜评估",
    "体温、心率、呼吸频率和疼痛评分",
    "腹部触诊评估腹胀、疼痛和胃肠内容物",
    "腹部影像评估胃肠积气、胃内容物、梗阻和泌尿影像线索",
    "口腔、门齿、臼齿和面部肿胀检查；必要时镇静下口腔/颅骨影像评估",
    "血糖、电解质、肾功能和酸碱/脱水相关指标按医生判断评估",
    "尿液颜色、沉渣、尿泥/尿石和排尿困难评估",
    "胸部听诊、鼻眼分泌物检查和胸部影像按需评估",
    "耳部、神经定位、眼震和头斜方向检查",
    "足底、皮肤、垫材接触面和外伤检查",
    "饮食结构、干草摄入、兔粮/零食比例和近期换粮记录",
    "未绝育母兔的腹部/生殖系统风险按需影像或进一步检查",
    "同住动物、应激、搬家、手术、疼痛或环境温度变化记录"
  ],
  "actions": [
    "兔停食、无粪、腹胀、呼吸困难、虚脱或低体温信号时，应按异宠急诊优先由医生评估。",
    "未排除梗阻、严重积气或休克样状态前，系统不得输出强饲、促动力药或任何给药指令。",
    "采集最近一次主动采食、排便、排尿、饮水、体重变化和疼痛行为，并标记是否需要影像/血检复核。",
    "把饮食结构、干草摄入、换粮、零食、垫材、笼底、温度和近期应激纳入病史。",
    "所有输出均为医生复核问题和鉴别方向，不是最终诊断、治疗方案或处方。"
  ],
  "questions": [
    "最后一次主动吃干草、兔粮或蔬菜是什么时候？停食持续多久？",
    "粪便是变少、变小、变软，还是完全没有？最后一次排便时间？",
    "是否腹胀、弓背、磨牙、拒绝活动、触碰腹部疼痛或突然安静不动？",
    "饮水和排尿是否减少？尿色是否变深、血尿、尿泥、尿少或疑似排尿困难？",
    "是否流口水、下巴湿、挑食草、磨牙、面部肿胀、眼鼻分泌物或口腔异味？",
    "是否张口呼吸、鼻翼用力、呼吸声异常、鼻/眼分泌物或不能平卧休息？",
    "是否头斜、转圈、眼震、站立不稳、抽搐或突然不能正常跳跃？",
    "年龄、性别、是否绝育？未绝育母兔是否有阴道分泌物、出血、腹部膨大或近期繁殖史？",
    "日常干草、兔粮、蔬菜、零食比例如何？最近是否换粮、减少干草或摄入异常食物？",
    "笼舍垫材、笼底、清洁频率、温度、潮湿情况和是否长期站在硬/湿表面？",
    "近期是否搬家、洗澡、惊吓、同伴变化、手术、外伤或明显疼痛事件？",
    "最近体重变化、精神、活动量、耳朵/四肢温度和是否有虚弱/虚脱？"
  ]
}
